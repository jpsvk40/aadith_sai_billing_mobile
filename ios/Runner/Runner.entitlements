<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Push notifications. "production" suits the App Store / TestFlight pipeline (Codemagic).
	     Switch to "development" only for a locally-signed dev build used to test push. -->
	<key>aps-environment</key>
	<string>production</string>
</dict>
</plist>
